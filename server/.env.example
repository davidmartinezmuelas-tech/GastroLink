PORT=3000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Requerido para autenticacion del cliente contra el proxy
AI_PROXY_TOKEN=
# Lista separada por comas. En produccion, definir siempre.
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173
MAX_REQUEST_SIZE=20kb
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30
TRUST_PROXY=false
